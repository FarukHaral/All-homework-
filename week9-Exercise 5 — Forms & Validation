<form id="signup-form" novalidate>
    <div class="form-group">
        <label for="full-name">Full Name</label>
        <input type="text" id="full-name" name="full-name" required>
        <span class="error-msg" id="full-name-error"></span>
    </div>

    <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required>
        <span class="error-msg" id="email-error"></span>
    </div>

    <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required>
        <div id="password-strength">
            <div id="strength-bar"></div>
        </div>
        <p id="strength-label">Password strength</p>
        <span class="error-msg" id="password-error"></span>
    </div>

    <div class="form-group">
        <label for="confirm-password">Confirm Password</label>
        <input type="password" id="confirm-password" name="confirm-password" required>
        <span class="error-msg" id="confirm-password-error"></span>
    </div>

    <div class="form-group">
        <label for="age">Age</label>
        <input type="number" id="age" name="age" min="18" max="120" required>
        <span class="error-msg" id="age-error"></span>
    </div>

    <div class="form-group">
        <label for="website">Website</label>
        <input type="url" id="website" name="website" placeholder="https://example.com">
        <span class="error-msg" id="website-error"></span>
    </div>

    <div class="form-group">
        <label for="country">Country</label>
        <select id="country" name="country" required>
            <option value="">Choose a country</option>
            <option value="turkey">Turkey</option>
            <option value="north-macedonia">North Macedonia</option>
            <option value="germany">Germany</option>
            <option value="united-kingdom">United Kingdom</option>
            <option value="united-states">United States</option>
        </select>
        <span class="error-msg" id="country-error"></span>
    </div>

    <div class="form-group">
        <label for="bio">Bio</label>
        <textarea id="bio" name="bio" maxlength="250"></textarea>
        <p id="bio-counter">0 / 200 characters</p>
        <span class="error-msg" id="bio-error"></span>
    </div>

    <div class="form-group checkbox-group">
        <input type="checkbox" id="terms" name="terms" required>
        <label for="terms">I accept the terms and conditions</label>
        <span class="error-msg" id="terms-error"></span>
    </div>

    <button type="submit" id="submit-button">Submit</button>
</form>

<div id="success-message" class="hidden">
    <h2>Success!</h2>
    <p>Your form has been submitted successfully.</p>
</div>
