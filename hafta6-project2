import random

"""
Pseudocode:
1. Show difficulty menu to the user.
2. Easy means numbers from 1 to 10.
3. Medium means numbers from 1 to 50.
4. Hard means numbers from 1 to 100.
5. Pick a random number based on the difficulty.
6. Ask the user to guess until the guess is correct.
7. Count each valid guess.
8. Tell the user if the guess is too low or too high.
9. Print the total number of guesses when the user wins.
"""

print("Choose difficulty:")
print("(1) Easy 1-10")
print("(2) Medium 1-50")
print("(3) Hard 1-100")

choice = input("Choice: ")

if choice == "1":
    max_number = 10
elif choice == "2":
    max_number = 50
elif choice == "3":
    max_number = 100
else:
    print("Invalid choice. Easy mode selected.")
    max_number = 10

secret = random.randint(1, max_number)
guesses = 0

while True:
    try:
        guess = int(input(f"Guess a number between 1 and {max_number}: "))
        guesses += 1

        if guess < secret:
            print("Too low!")
        elif guess > secret:
            print("Too high!")
        else:
            print(f"Correct! You got it in {guesses} guesses.")
            break

    except ValueError:
        print("Error: Please enter a valid number.")
