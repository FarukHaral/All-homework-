import random

"""
Pseudocode:
1. Import the random module.
2. Pick a random secret number between 1 and 10.
3. Set the guess counter to 0.
4. Ask the user to guess a number.
5. While the guess is not equal to the secret number:
   - Increase the guess counter.
   - If the guess is too low, tell the user.
   - If the guess is too high, tell the user.
   - Ask the user to guess again.
6. When the user guesses correctly:
   - Increase the guess counter one last time.
   - Print how many guesses it took.
"""

# Step 1 — Pick a random number between 1 and 10
secret = random.randint(1, 10)

# Step 2 — Set up a counter
guesses = 0

# Step 3 — Ask the user for their first guess
guess = int(input("Guess a number between 1 and 10: "))

# Step 4 — Loop until the guess is correct
while guess != secret:
    guesses += 1

    if guess < secret:
        guess = int(input("Too low! Try again: "))
    else:
        guess = int(input("Too high! Try again: "))

# Count the correct guess
guesses += 1

print(f"Correct! You got it in {guesses} guesses.")


# Project 2 — Number Guessing Game
