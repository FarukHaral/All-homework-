"""
Pseudocode:
1. Ask the user to enter a sentence.
2. Convert the sentence to lowercase so "The" and "the" are counted the same.
3. Remove punctuation marks like commas, periods, exclamation marks, and question marks.
4. Split the sentence into a list of words.
5. Count the total number of words using len().
6. Count the total number of characters without spaces.
7. Create an empty dictionary for word frequency.
8. Loop through each word and count how many times it appears.
9. Sort the word frequency from most common to least common.
10. Print the total words, total characters, and word frequency.
"""

sentence = input("Enter a sentence: ")

# Convert to lowercase
sentence = sentence.lower()

# Strip punctuation
punctuation = ",.!?"

for mark in punctuation:
    sentence = sentence.replace(mark, "")

# Split into words
words = sentence.split()

# Count total words
total_words = len(words)

# Count total characters excluding spaces
total_characters = len(sentence.replace(" ", ""))

# Build word frequency dictionary
frequency = {}

for word in words:
    if word in frequency:
        frequency[word] += 1
    else:
        frequency[word] = 1

# Sort word frequency from most to least common
sorted_frequency = sorted(frequency.items(), key=lambda item: item[1], reverse=True)

# Print results
print(f"Total words: {total_words}")
print(f"Total characters (no spaces): {total_characters}")

print("Word frequency:")
for word, count in sorted_frequency:
    print(f"  {word} -> {count}")
