-- =========================================================
-- 7.8 — Transaction: Library Loan (library.db)
-- =========================================================

BEGIN TRANSACTION;

UPDATE books
SET available_copies = available_copies - 1
WHERE id = 3
  AND available_copies > 0;

INSERT INTO loans (member_id, book_id, loan_date, due_date, return_date)
SELECT 3, 3, '2025-04-01', '2025-04-15', NULL
WHERE (
    SELECT available_copies
    FROM books
    WHERE id = 3
) >= 0;

COMMIT;


-- =========================================================
-- 7.9 — EXPLAIN Query Plan (school.db)
-- =========================================================

CREATE INDEX IF NOT EXISTS idx_students_email
ON students(email);

EXPLAIN QUERY PLAN
SELECT *
FROM students
WHERE LOWER(email) = 'alice@school.edu';

EXPLAIN QUERY PLAN
SELECT *
FROM students
WHERE email = 'alice@school.edu';

-- Explanation:
-- Version A is slower because LOWER(email) applies a function to every email value.
-- This prevents SQLite from using the normal email index efficiently.
-- Version B is faster because it compares the email column directly,
-- so SQLite can use the index on students(email).


