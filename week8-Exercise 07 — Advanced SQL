-- =========================================================
-- 7.2 — Create a View: Active Enrollments (school.db)
-- =========================================================

DROP VIEW IF EXISTS enrollment_details;

CREATE VIEW enrollment_details AS
SELECT
    s.first_name || ' ' || s.last_name AS student_name,
    c.code AS course_code,
    c.title AS course_title,
    g.letter_grade
FROM enrollments e
JOIN students s ON e.student_id = s.id
JOIN courses c ON e.course_id = c.id
LEFT JOIN grades g ON e.id = g.enrollment_id;

SELECT *
FROM enrollment_details
WHERE letter_grade = 'A';


-- =========================================================
-- 7.3 — Create a View: Course Stats (school.db)
-- =========================================================

DROP VIEW IF EXISTS course_statistics;

CREATE VIEW course_statistics AS
SELECT
    c.code AS course_code,
    c.title AS course_title,
    COUNT(e.id) AS enrolled_students,
    ROUND(AVG(g.final_exam), 1) AS average_final_exam
FROM courses c
LEFT JOIN enrollments e ON c.id = e.course_id
LEFT JOIN grades g ON e.id = g.enrollment_id
GROUP BY c.id, c.code, c.title;

SELECT *
FROM course_statistics;


